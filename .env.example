# Copie para .env.local e preencha os valores.

# Base da API consumida pelo BFF (rotas /api/events/*).
# — Produção (somente leitura): URL do GitHub Pages / hospedagem estática.
# — Local com mutações: json-server (ex.: http://localhost:3001), ver .cursor/rules/03-api-reference.mdc
NEXT_PUBLIC_EXTERNAL_API_URL=""
NEXT_PUBLIC_EXTERNAL_API_KEY=""

# App
NEXT_PUBLIC_APP_NAME="Player Eventos"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
